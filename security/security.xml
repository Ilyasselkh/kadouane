<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="moduleacces" model="res.groups">
            <field name="name">access douane</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_douane" model="res.groups">
            <field name="name">gestion douane</field>
            <field name="implied_ids" eval="[(4, ref('moduleacces'))]"/>
        </record>

        <record id="group_restransport" model="res.groups">
            <field name="name">responsable Transport</field>
            <field name="implied_ids" eval="[(4, ref('moduleacces'))]"/>
        </record>

        <record id="group_adv" model="res.groups">
            <field name="name">ADV</field>
            <field name="implied_ids" eval="[(4, ref('moduleacces'))]"/>
        </record>

        <record id="group_resadv" model="res.groups">
            <field name="name">responsable ADV</field>
            <field name="implied_ids" eval="[(4, ref('group_adv')), (4, ref('moduleacces'))]"/>
        </record>

        <record id="group_opmag" model="res.groups">
            <field name="name">Operateur mag</field>
            <field name="implied_ids" eval="[(4, ref('moduleacces'))]"/>
        </record>

        <record id="group_resmag" model="res.groups">
            <field name="name">responsable mag</field>
            <field name="implied_ids" eval="[(4, ref('group_opmag')), (4, ref('moduleacces'))]"/>
        </record>

        <record id="group_key" model="res.groups">
            <field name="name">Key User</field>
            <field name="implied_ids" eval="[(4, ref('group_douane')), (4, ref('group_restransport')), (4, ref('group_resadv')), (4, ref('group_adv')), (4, ref('group_resmag')), (4, ref('group_opmag')), (4, ref('moduleacces'))]"/>
        </record>

        <record id="group_log_manager" model="res.groups">
            <field name="name">Logistics manager</field>
            <field name="implied_ids" eval="[(4, ref('group_douane')), (4, ref('group_restransport')), (4, ref('group_resadv')), (4, ref('group_adv')), (4, ref('group_resmag')), (4, ref('group_opmag')), (4, ref('moduleacces'))]"/>
        </record>

    </data>
</odoo>
