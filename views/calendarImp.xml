<odoo>
  <data>

    <record id="kadouane.view_imp_calendar" model="ir.ui.view">
      <field name="name">kadouane.kadouaneimp.calendar.view</field>
      <field name="model">kadouane.dmdimport</field>
      <field name="arch" type="xml">
        <calendar string="Calendrier des clients (ETD)"
                  date_start="pickingETD"
                  color="state"
                  quick_create="false"
                  event_open_popup="true"
                  create="true"
                  edit="true"
                  delete="true">
          <field name="referenceID"/>
          <field name="create_uid" filters="true"/>
          <field name="supplier_id" filters="true"/>
          <field name="state" filters="true"/>
          <field name="incoterm"/>
        </calendar>
      </field>
    </record>

    <record id="kadouane.view_impdateOp_calendar" model="ir.ui.view">
      <field name="name">kadouane.kadouaneimpDateETA.calendar.view</field>
      <field name="model">kadouane.dmdimport</field>
      <field name="arch" type="xml">
        <calendar string="Calendrier des clients (ETA)"
                  date_start="pickingETA"
                  color="state"
                  quick_create="false"
                  event_open_popup="true"
                  create="true"
                  edit="true"
                  delete="true">
          <field name="referenceID"/>
          <field name="create_uid" filters="true"/>
          <field name="supplier_id" filters="true"/>
          <field name="state" filters="true"/>
          <field name="incoterm"/>
        </calendar>
      </field>
    </record>

  </data>
</odoo>
