<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="seq_kadouane_order" model="ir.sequence">
        <field name="name">Douane Order</field>
        <field name="code">kadouane.kadouane.sequence</field>
        <field name="prefix">%(year)s%(month)s</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>


    <record id="seq_kadouane_order_Import" model="ir.sequence">
        <field name="name">Douane Order Import</field>
        <field name="code">kadouane.dmdimport.sequence</field>
        <field name="prefix">I_%(year)s%(month)s</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
